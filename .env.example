# ===================================
# CONFIGURAÇÕES DO DJANGO
# ===================================

# Chave secreta (gere uma nova em produção)
DJANGO_SECRET_KEY=django-insecure-change-this-in-production

# Debug mode (True para desenvolvimento, False para produção)
DJANGO_DEBUG=True

# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF Trusted Origins (para segurança em produção)
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ===================================
# BANCO DE DADOS (opcional se usar SQLite)
# ===================================
# DATABASE_URL=sqlite:///db.sqlite3

# Para PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/fernanda_doces

# ===================================
# SEGURANÇA (produção)
# ===================================

# Habilita redirecionamento para HTTPS
# ALLOW_HTTP=False

# ===================================
# WHATSAPP
# ===================================

# Número do WhatsApp da Fernanda (com código do país)
WHATSAPP_NUMBER=5532984069242

# ===================================
# EMAIL (opcional)
# ===================================

# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=seu.email@gmail.com
# EMAIL_HOST_PASSWORD=sua-senha-de-app
# EMAIL_USE_TLS=True

# ===================================
# NOTA
# ===================================
# 1. Copie este arquivo para .env e preencha com valores reais
# 2. Nunca commit o arquivo .env com dados sensíveis
# 3. No Railway/produção, configure as variáveis no painel de admin
